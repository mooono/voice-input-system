# Azure Speech Service
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=japaneast
SPEECH_LANGUAGE=ja-JP

# Azure OpenAI (optional — set ENABLE_REFINEMENT=true to use)
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-nano
AZURE_OPENAI_API_VERSION=1
# Refinement system prompt (optional — override to customise text refinement behaviour)
# REFINE_SYSTEM_PROMPT=音声テキストを整形し出力。フィラーを削除。誤字修正、句読点補正。意味を変えず整形後テキストのみ返す。
# Latency tuning
AZURE_OPENAI_TIMEOUT_SEC=1.8
AZURE_OPENAI_MAX_OUTPUT_TOKENS=96
AZURE_OPENAI_TEMPERATURE=0.0
REFINE_MIN_CHARS_FOR_API=8

# App Settings
HOTKEY=ctrl+shift+space
ENABLE_REFINEMENT=false
# Output mode: paste|type
OUTPUT_INSERT_MODE=paste
OUTPUT_POST_HOTKEY_DELAY_SEC=0.25
